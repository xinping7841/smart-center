  "target_groups": [
    {
      "id": "niren_poe_kp_i101_192_168_50_89",
      "name": "POE-KP-I101 192.168.50.89 AT",
      "protocol": "tcp",
      "mode": "single",
      "host": "192.168.50.89",
      "port": 44489,
      "timeout_ms": 2000,
      "wait_ms": 500,
      "send_strategy": "serial",
      "enabled": true
    }
  ],
  "commands": [
    {
      "id": "niren_at_ping",
      "name": "AT ping",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT",
      "wait_ms": 500,
      "enabled": true
    },
    {
      "id": "niren_at_device_info",
      "name": "Read device info",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT+DEVICEINFO=?",
      "wait_ms": 700,
      "enabled": true
    },
    {
      "id": "niren_at_do_read",
      "name": "Read DO channel",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT+STACH{{channel}}=?",
      "params": [
        {"id": "channel", "label": "Channel", "type": "int", "default": 1, "min": 1, "max": 64, "step": 1}
      ],
      "wait_ms": 700,
      "enabled": true
    },
    {
      "id": "niren_at_do_on",
      "name": "DO on",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT+STACH{{channel}}=1",
      "params": [
        {"id": "channel", "label": "Channel", "type": "int", "default": 1, "min": 1, "max": 64, "step": 1}
      ],
      "wait_ms": 700,
      "enabled": true
    },
    {
      "id": "niren_at_do_off",
      "name": "DO off",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT+STACH{{channel}}=0",
      "params": [
        {"id": "channel", "label": "Channel", "type": "int", "default": 1, "min": 1, "max": 64, "step": 1}
      ],
      "wait_ms": 700,
      "enabled": true
    },
    {
      "id": "niren_at_do_pulse",
      "name": "DO pulse",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT+STACH{{channel}}=3,{{seconds}}",
      "params": [
        {"id": "channel", "label": "Channel", "type": "int", "default": 1, "min": 1, "max": 64, "step": 1},
        {"id": "seconds", "label": "Seconds", "type": "int", "default": 1, "min": 1, "max": 100000, "step": 1}
      ],
      "wait_ms": 700,
      "enabled": true
    },
    {
      "id": "niren_at_di_read",
      "name": "Read DI channel",
      "category": "Niren AT",
      "protocol": "tcp",
      "format": "str",
      "line_ending": "crlf",
      "payload_template": "AT+OCCH{{channel}}=?",
      "params": [
        {"id": "channel", "label": "Channel", "type": "int", "default": 1, "min": 1, "max": 64, "step": 1}
      ],
      "wait_ms": 700,
      "enabled": true
    }
