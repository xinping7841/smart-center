{
  "meta": {
    "id": "niren_poe_kp_i101_at",
    "name": "Niren POE-KP-I101 AT relay",
    "vendor": "Niren",
    "description": "AT-over-TCP commands for POE-KP-I101 RJ45/WIFI relay controllers. Change host, port, channel and timeout per device after import.",
