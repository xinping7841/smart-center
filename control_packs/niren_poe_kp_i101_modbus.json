{
  "meta": {
    "id": "niren_poe_kp_i101_modbus",
    "name": "Niren POE-KP-I101 Modbus relay",
    "vendor": "Niren",
    "description": "Modbus commands for POE-KP-I101 relay controllers. Use modbus_rtu for RTU-over-TCP or modbus_tcp for standard MBAP framing, depending on the device configuration.",
